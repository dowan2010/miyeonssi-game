# ── PostgreSQL (Supabase) ───────────────────────────────────────
# Supabase 대시보드 > Project Settings > Database > Connection string (URI)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# ── Google OAuth ────────────────────────────────────────────────
# Google Cloud Console > API 및 서비스 > 사용자 인증 정보 에서 생성
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# 개발: http://localhost:3001/auth/google/callback
# 배포: https://yourapp.onrender.com/auth/google/callback
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

# 로그인 후 리다이렉트 주소
CLIENT_URL=http://localhost:5173

# 세션 서명용 랜덤 문자열 (openssl rand -base64 32 로 생성)
SESSION_SECRET=랜덤하고-긴-문자열로-바꿔주세요

# ── 포트 ────────────────────────────────────────────────────────
PORT=3001
